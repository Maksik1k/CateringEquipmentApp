<Page x:Class="CateringEquipmentApp.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid>
        <Grid.Resources>
            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="GridLinesVisibility" Value="None"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
                <Setter Property="CanUserAddRows" Value="False"/>
                <Setter Property="CanUserDeleteRows" Value="False"/>
                <Setter Property="CanUserResizeRows" Value="False"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="SelectionUnit" Value="FullRow"/>
                <Setter Property="AlternatingRowBackground" Value="{DynamicResource AppTableAltRowBrush}"/>
                <Setter Property="RowBackground" Value="White"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{DynamicResource AppTableHeaderBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Padding" Value="14,12"/>
                <Setter Property="Height" Value="46"/>
                <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>

            <Style TargetType="DataGridCell">
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="BorderBrush" Value="#E8EEF4"/>
                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource AppTableSelectedBrush}"/>
                        <Setter Property="Foreground" Value="#0F4360"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style TargetType="DataGridRow">
                <Setter Property="MinHeight" Value="42"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource AppTableHoverBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="ReportComboStyle" TargetType="ComboBox">
                <Setter Property="Height" Value="46"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
                <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource AppControlBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Border x:Name="ComboBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="16">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="46"/>
                                        </Grid.ColumnDefinitions>

                                        <ContentPresenter Margin="16,0,12,0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          RecognizesAccessKey="True"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>

                                        <ToggleButton Grid.Column="1"
                                                      x:Name="DropDownToggle"
                                                      Focusable="False"
                                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                      Background="Transparent"
                                                      BorderBrush="Transparent"
                                                      BorderThickness="0"
                                                      Cursor="Hand">
                                            <ToggleButton.Template>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="Transparent">
                                                        <Path x:Name="ArrowPath"
                                                              Width="12"
                                                              Height="7"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Fill="#5A778D"
                                                              Data="M 0 0 L 12 0 L 6 7 Z"
                                                              RenderTransformOrigin="0.5,0.5">
                                                            <Path.RenderTransform>
                                                                <RotateTransform Angle="0"/>
                                                            </Path.RenderTransform>
                                                        </Path>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Trigger.EnterActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="ArrowPath"
                                                                                         Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)"
                                                                                         To="180"
                                                                                         Duration="0:0:0.18"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.EnterActions>
                                                            <Trigger.ExitActions>
                                                                <BeginStoryboard>
                                                                    <Storyboard>
                                                                        <DoubleAnimation Storyboard.TargetName="ArrowPath"
                                                                                         Storyboard.TargetProperty="RenderTransform.(RotateTransform.Angle)"
                                                                                         To="0"
                                                                                         Duration="0:0:0.18"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </Trigger.ExitActions>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </ToggleButton.Template>
                                        </ToggleButton>
                                    </Grid>
                                </Border>

                                <Popup x:Name="PART_Popup"
                                       Placement="Bottom"
                                       Margin="0,6,0,0"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Fade"
                                       IsOpen="{TemplateBinding IsDropDownOpen}">
                                    <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                            MaxHeight="280"
                                            Background="White"
                                            BorderBrush="{DynamicResource AppControlBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="16">
                                        <ScrollViewer>
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ComboBorder" Property="Background" Value="#FBFDFF"/>
                                    <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#BFD3E2"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="ComboBorder" Property="Background" Value="White"/>
                                    <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource AppControlFocusBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ComboBoxItem">
                <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="14,10"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#EFF6FB"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#DDF0FB"/>
                                    <Setter Property="Foreground" Value="#0F4360"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.2*"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Margin="0,0,22,0">
                    <TextBlock Text="Аналитика и отчёты"
                               Foreground="{DynamicResource AppTextMutedBrush}"
                               FontSize="13"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="ReportTitleText"
                               Margin="0,8,0,0"
                               Text="Отчёт по ремонтам"
                               FontSize="30"
                               FontWeight="Bold"
                               FontFamily="Bahnschrift"
                               Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                    <TextBlock x:Name="ReportDescriptionText"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource AppTextSecondaryBrush}"
                               FontSize="15"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{DynamicResource AppSurfaceBrush}"
                        CornerRadius="20"
                        BorderBrush="{DynamicResource AppCardBorderBrush}"
                        BorderThickness="1"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Тип отчёта"
                                   Foreground="{DynamicResource AppTextMutedBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                        <ComboBox x:Name="ReportSelector"
                                  Margin="0,10,0,0"
                                  Style="{StaticResource ReportComboStyle}"
                                  DisplayMemberPath="Название"
                                  SelectedValuePath="Ключ"
                                  SelectionChanged="ReportSelector_SelectionChanged"/>
                        <Button x:Name="ExportButton"
                                Margin="0,14,0,0"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="ExportButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Image Source="{StaticResource ReportsIcon}" Width="16" Height="16" Margin="0,0,8,0"/>
                                <TextBlock Text="Экспорт CSV" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,14">
                    <Border Background="#E8F3FA"
                            CornerRadius="14"
                            Padding="12,6"
                            HorizontalAlignment="Left"
                            DockPanel.Dock="Left">
                        <TextBlock Text="Данные по выбранному отчёту"
                                   Foreground="#1C5573"
                                   FontWeight="SemiBold"/>
                    </Border>
                </DockPanel>

                <Grid Grid.Row="1">
                    <DataGrid x:Name="ReportGrid"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"
                              RowHeaderWidth="0"/>

                    <Border x:Name="EmptyStatePanel"
                            Background="#FAFCFE"
                            CornerRadius="22"
                            BorderBrush="{DynamicResource AppCardBorderBrush}"
                            BorderThickness="1"
                            Padding="28"
                            Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="58"
                                    Height="58"
                                    CornerRadius="18"
                                    Background="#E8F3FA"
                                    HorizontalAlignment="Center">
                                <Image Source="{StaticResource ReportsIcon}" Width="26" Height="26" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Для этого отчёта пока нет данных"
                                       Margin="0,14,0,0"
                                       FontSize="21"
                                       FontWeight="SemiBold"
                                       FontFamily="Bahnschrift"
                                       Foreground="{DynamicResource AppTextPrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Попробуйте выбрать другой тип отчёта или сначала добавить записи в систему."
                                       Margin="0,10,0,0"
                                       FontSize="14"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       MaxWidth="460"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
