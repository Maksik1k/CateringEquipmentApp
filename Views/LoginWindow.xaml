<Window x:Class="CateringEquipmentApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="КухТех Контроль"
        Icon="{StaticResource KitchenCareIcon}"
        Height="660"
        Width="580"
        MinHeight="660"
        MinWidth="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource AppShellBackgroundBrush}"
        FontFamily="Segoe UI"
        Opacity="0">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.32"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <LinearGradientBrush x:Key="LoginBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F5F1EA" Offset="0"/>
            <GradientStop Color="#EEE6DA" Offset="0.58"/>
            <GradientStop Color="#FFFCF7" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="LoginAccentBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2F7C85" Offset="0"/>
            <GradientStop Color="#3D8F86" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="LoginInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="InputBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="#CBBEAF"/>
                                <Setter TargetName="InputBorder" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="InputBorder" Property="BorderBrush" Value="{DynamicResource AppControlFocusBrush}"/>
                                <Setter TargetName="InputBorder" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginPasswordStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="PasswordBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PasswordBorder" Property="BorderBrush" Value="#CBBEAF"/>
                                <Setter TargetName="PasswordBorder" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="PasswordBorder" Property="BorderBrush" Value="{DynamicResource AppControlFocusBrush}"/>
                                <Setter TargetName="PasswordBorder" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource LoginBackgroundBrush}">
        <Canvas IsHitTestVisible="False" Opacity="0.55">
            <Ellipse Width="220" Height="220" Canvas.Left="-50" Canvas.Top="-20" Fill="#FAF4EA"/>
            <Ellipse Width="170" Height="170" Canvas.Right="18" Canvas.Top="62" Fill="#F4ECE1"/>
            <Ellipse Width="130" Height="130" Canvas.Left="420" Canvas.Top="500" Fill="#F6EFE5"/>
        </Canvas>

        <Border Margin="18"
                Background="#F7F2EA"
                CornerRadius="34"
                BorderBrush="#D5CBBE"
                BorderThickness="1">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="#F3EBDD"
                        CornerRadius="24"
                        Padding="16"
                        Opacity="0">
                    <Border.RenderTransform>
                        <TranslateTransform Y="-14"/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0"
                                                     To="1"
                                                     Duration="0:0:0.34"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                     From="-14"
                                                     To="0"
                                                     Duration="0:0:0.34"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="56"
                                Height="56"
                                Background="{StaticResource LoginAccentBrush}"
                                CornerRadius="18">
                            <Image Source="{StaticResource KitchenCareIcon}"
                                   Width="56"
                                   Height="56"
                                   Stretch="Uniform"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="14,2,0,0">
                            <TextBlock Text="КухТех Контроль"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                            <TextBlock Text="Система учёта оборудования общепита"
                                       Margin="0,4,0,0"
                                       FontSize="11.5"
                                       Foreground="{DynamicResource AppTextSecondaryBrush}"/>
                            <Border Margin="0,10,0,0"
                                    Background="#FFFCF7"
                                    BorderBrush="#DDD1C3"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="10,7">
                                <TextBlock Text="Ремонты, замены, санитарная обработка и контроль сроков в одном окне."
                                           FontSize="10.8"
                                           Foreground="{DynamicResource AppTextSecondaryBrush}"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,10,0,0"
                        Padding="22"
                        Background="{DynamicResource AppCardBrush}"
                        CornerRadius="30"
                        BorderBrush="{DynamicResource AppCardBorderBrush}"
                        BorderThickness="1"
                        Opacity="0">
                    <Border.RenderTransform>
                        <TranslateTransform Y="20"/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0"
                                                     To="1"
                                                     BeginTime="0:0:0.08"
                                                     Duration="0:0:0.36"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                     From="20"
                                                     To="0"
                                                     BeginTime="0:0:0.08"
                                                     Duration="0:0:0.36"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>

                    <StackPanel>
                        <TextBlock Text="Авторизация"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   FontFamily="Bahnschrift"
                                   Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                        <TextBlock Text="Введите логин и пароль сотрудника, чтобы открыть рабочее приложение."
                                   Foreground="{DynamicResource AppTextSecondaryBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"/>

                        <Grid Margin="0,16,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Логин"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextSecondaryBrush}"
                                           Margin="0,0,0,6"/>
                                <TextBox x:Name="LoginTextBox"
                                         Style="{StaticResource LoginInputStyle}"
                                         Text="user1"
                                         Opacity="0">
                                    <TextBox.RenderTransform>
                                        <TranslateTransform X="-16"/>
                                    </TextBox.RenderTransform>
                                    <TextBox.Triggers>
                                        <EventTrigger RoutedEvent="TextBox.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0"
                                                                     To="1"
                                                                     BeginTime="0:0:0.16"
                                                                     Duration="0:0:0.28"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                                     From="-16"
                                                                     To="0"
                                                                     BeginTime="0:0:0.16"
                                                                     Duration="0:0:0.28"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBox.Triggers>
                                </TextBox>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                <TextBlock Text="Пароль"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppTextSecondaryBrush}"
                                           Margin="0,0,0,6"/>
                                <PasswordBox x:Name="PasswordBox"
                                             Style="{StaticResource LoginPasswordStyle}"
                                             Password="pass1"
                                             Opacity="0">
                                    <PasswordBox.RenderTransform>
                                        <TranslateTransform X="16"/>
                                    </PasswordBox.RenderTransform>
                                    <PasswordBox.Triggers>
                                        <EventTrigger RoutedEvent="PasswordBox.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="0"
                                                                     To="1"
                                                                     BeginTime="0:0:0.22"
                                                                     Duration="0:0:0.28"/>
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                                     From="16"
                                                                     To="0"
                                                                     BeginTime="0:0:0.22"
                                                                     Duration="0:0:0.28"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </PasswordBox.Triggers>
                                </PasswordBox>
                            </StackPanel>
                        </Grid>

                        <Button x:Name="LoginButton"
                                Height="50"
                                Margin="0,18,0,0"
                                Background="{StaticResource LoginAccentBrush}"
                                Foreground="White"
                                BorderBrush="Transparent"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Click="LoginButton_Click"
                                RenderTransformOrigin="0.5,0.5">
                            <Button.RenderTransform>
                                <TranslateTransform Y="0"/>
                            </Button.RenderTransform>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="ButtonBorder"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="16">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                                     To="-1"
                                                                     Duration="0:0:0.16"/>
                                                    <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="0.94"
                                                                     Duration="0:0:0.16"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                                     To="0"
                                                                     Duration="0:0:0.16"/>
                                                    <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     To="1"
                                                                     Duration="0:0:0.16"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Image Source="{StaticResource LoginIcon}"
                                       Width="18"
                                       Height="18"
                                       Margin="0,0,10,0"/>
                                <TextBlock Text="Войти в систему"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <TextBlock x:Name="StatusTextBlock"
                                   Foreground="{DynamicResource AppDangerBrush}"
                                   Margin="0,10,0,0"
                                   FontSize="12.5"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
