<Window x:Class="CateringEquipmentApp.Views.AppDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сообщение"
        Icon="{StaticResource KitchenCareIcon}"
        Width="560"
        Height="320"
        MinWidth="560"
        MinHeight="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppWindowBackgroundBrush}">
    <Grid Margin="18">
        <Border Background="{DynamicResource AppSurfaceAltBrush}"
                CornerRadius="30"
                BorderBrush="{DynamicResource AppCardBorderBrush}"
                BorderThickness="1">
            <Grid Margin="26">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Background="{DynamicResource AppSurfaceBrush}"
                        CornerRadius="24"
                        BorderBrush="{DynamicResource AppCardBorderBrush}"
                        BorderThickness="1"
                        Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="AccentBubble"
                                Width="64"
                                Height="64"
                                CornerRadius="22"
                                Background="{DynamicResource AppAccentBrush}"
                                VerticalAlignment="Top">
                            <TextBlock x:Name="AccentGlyph"
                                       FontSize="31"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="i"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="18,2,0,0">
                            <TextBlock x:Name="TitleText"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       FontFamily="Bahnschrift"
                                       Foreground="{DynamicResource AppTextPrimaryBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="SubtitleText"
                                       Margin="0,8,0,0"
                                       FontSize="15"
                                       Foreground="{DynamicResource AppTextMutedBrush}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Margin="0,18,0,0"
                        Background="{DynamicResource AppCardBrush}"
                        CornerRadius="22"
                        BorderBrush="{DynamicResource AppCardBorderBrush}"
                        BorderThickness="1"
                        Padding="22">
                    <TextBlock x:Name="MessageText"
                               TextWrapping="Wrap"
                               FontSize="17"
                               LineHeight="26"
                               Foreground="{DynamicResource AppTextSecondaryBrush}"
                               VerticalAlignment="Top"/>
                </Border>

                <Grid Grid.Row="2" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#E8F3FA"
                            CornerRadius="14"
                            Padding="12,8"
                            VerticalAlignment="Center"
                            Margin="0,0,14,0">
                        <TextBlock Text="Окно подтверждения и уведомлений приложения."
                                   Foreground="#1C5573"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Button x:Name="CancelButton"
                            Grid.Column="1"
                            Width="126"
                            Style="{StaticResource ActionButtonStyle}"
                            Margin="0,0,10,0"
                            Background="#DCE7EF"
                            Foreground="{DynamicResource AppTextPrimaryBrush}"
                            BorderBrush="Transparent"
                            Click="CancelButton_Click"
                            Visibility="Collapsed">
                        Отмена
                    </Button>

                    <Button x:Name="OkButton"
                            Grid.Column="2"
                            Width="146"
                            Style="{StaticResource ActionButtonStyle}"
                            Margin="0"
                            Click="OkButton_Click">
                        Понятно
                    </Button>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
