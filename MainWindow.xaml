<Window x:Class="CateringEquipmentApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="КухТех Контроль"
        Icon="{StaticResource KitchenCareIcon}"
        Height="940"
        Width="1520"
        MinHeight="820"
        MinWidth="1320"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppShellBackgroundBrush}"
        FontFamily="Segoe UI"
        Opacity="0">
    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0"
                                     To="1"
                                     Duration="0:0:0.35"/>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <LinearGradientBrush x:Key="ShellBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F3EEE6" Offset="0"/>
            <GradientStop Color="#FFFCF6" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SidebarBackground" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#26363C" Offset="0"/>
            <GradientStop Color="#304247" Offset="0.55"/>
            <GradientStop Color="#3A4E54" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="20,14,16,14"/>
            <Setter Property="Foreground" Value="#F7F2EA"/>
            <Setter Property="Background" Value="{DynamicResource AppSidebarButtonBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppSidebarBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <TranslateTransform Y="0"/>
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <Grid>
                                <Border x:Name="AccentBar"
                                        Width="4"
                                        Height="24"
                                        Margin="12,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource AppAccentBrush}"
                                        CornerRadius="2"
                                        Opacity="0.25"/>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AppSidebarButtonHoverBrush}"/>
                                <Setter TargetName="AccentBar" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource AppSidebarSelectedBrush}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource AppSidebarSelectedBrush}"/>
                                <Setter TargetName="AccentBar" Property="Opacity" Value="1"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Children[0].Y"
                                                         To="-1"
                                                         Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Children[0].Y"
                                                         To="0"
                                                         Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Margin" Value="0,0,18,18"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppCardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="16"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0"
                                             To="1"
                                             Duration="0:0:0.28"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                             From="16"
                                             To="0"
                                             Duration="0:0:0.28"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource ShellBackground}">
        <Border Margin="18"
                CornerRadius="32"
                Background="{DynamicResource AppSurfaceAltBrush}"
                BorderBrush="{DynamicResource AppCardBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="324"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource SidebarBackground}"
                        CornerRadius="32,0,0,32"
                        Opacity="0">
                    <Border.RenderTransform>
                        <TranslateTransform X="-28"/>
                    </Border.RenderTransform>
                    <Border.Triggers>
                        <EventTrigger RoutedEvent="Border.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0"
                                                     To="1"
                                                     Duration="0:0:0.42"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.X)"
                                                     From="-28"
                                                     To="0"
                                                     Duration="0:0:0.42"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Border.Triggers>

                    <Grid Margin="22,28,20,28">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Padding="20"
                                Background="#F7F2EA"
                                BorderBrush="#D5CBBE"
                                BorderThickness="1"
                                CornerRadius="28"
                                Opacity="0">
                            <Border.RenderTransform>
                                <TranslateTransform Y="12"/>
                            </Border.RenderTransform>
                            <Border.Triggers>
                                <EventTrigger RoutedEvent="Border.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0"
                                                             To="1"
                                                             BeginTime="0:0:0.08"
                                                             Duration="0:0:0.28"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                             From="12"
                                                             To="0"
                                                             BeginTime="0:0:0.08"
                                                             Duration="0:0:0.28"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </Border.Triggers>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="64"
                                        Height="64"
                                        Background="#2F7C85"
                                        CornerRadius="20"
                                        VerticalAlignment="Top">
                                    <Image Source="{StaticResource KitchenCareIcon}"
                                           Width="64"
                                           Height="64"
                                           Stretch="Uniform"/>
                                </Border>

                                <StackPanel Grid.Column="1" Margin="16,4,0,0">
                                    <TextBlock Text="КухТех Контроль"
                                               Foreground="#233239"
                                               FontSize="24"
                                               FontWeight="Bold"
                                               FontFamily="Bahnschrift"/>
                                    <TextBlock Text="Система учёта оборудования общепита"
                                               Foreground="#5D7077"
                                               FontSize="13.5"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <Border Grid.Row="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,18,0,0"
                                        Background="#ECE4D9"
                                        BorderBrush="#DDD1C3"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="14,12">
                                    <TextBlock Text="Ремонты, замены, санитарная обработка и контроль сроков в одном рабочем интерфейсе."
                                               Foreground="#43565D"
                                               FontSize="12.8"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="1"
                                    Margin="6,20,0,18"
                                    Opacity="0">
                            <StackPanel.RenderTransform>
                                <TranslateTransform Y="10"/>
                            </StackPanel.RenderTransform>
                            <StackPanel.Triggers>
                                <EventTrigger RoutedEvent="StackPanel.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0"
                                                             To="1"
                                                             BeginTime="0:0:0.14"
                                                             Duration="0:0:0.28"/>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                             From="10"
                                                             To="0"
                                                             BeginTime="0:0:0.14"
                                                             Duration="0:0:0.28"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </StackPanel.Triggers>
                            <TextBlock Text="Разделы системы"
                                       Foreground="#EEE7DD"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       TextOptions.TextFormattingMode="Display"/>
                            <Border Margin="0,10,18,0"
                                    Height="1"
                                    Background="#62767B"
                                    Opacity="0.45"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Disabled"
                                      PanningMode="VerticalOnly">
                            <StackPanel x:Name="NavButtonsPanel"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="26" Opacity="0">
                    <Grid.RenderTransform>
                        <TranslateTransform Y="24"/>
                    </Grid.RenderTransform>
                    <Grid.Triggers>
                        <EventTrigger RoutedEvent="Grid.Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0"
                                                     To="1"
                                                     BeginTime="0:0:0.12"
                                                     Duration="0:0:0.38"/>
                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(TranslateTransform.Y)"
                                                     From="24"
                                                     To="0"
                                                     BeginTime="0:0:0.12"
                                                     Duration="0:0:0.38"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Grid.Triggers>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="SectionTitleText"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       FontFamily="Bahnschrift"
                                       Foreground="{DynamicResource AppTextPrimaryBrush}"/>
                            <TextBlock x:Name="SectionSubtitleText"
                                       Foreground="{DynamicResource AppTextMutedBrush}"
                                       FontSize="15"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    MaxWidth="420">
                            <TextBlock x:Name="CurrentUserText"
                                       HorizontalAlignment="Right"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextPrimaryBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="CurrentRoleText"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource AppTextMutedBrush}"
                                       TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,14,0,0">
                                <Button Style="{StaticResource ActionButtonStyle}"
                                        Click="RefreshButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{StaticResource RefreshIcon}" Width="16" Height="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="Обновить" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource ActionButtonStyle}"
                                        Background="{DynamicResource AppDangerBrush}"
                                        Click="LogoutButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="{StaticResource LogoutIcon}" Width="16" Height="16" Margin="0,0,8,0"/>
                                        <TextBlock Text="Сменить пользователя" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <Frame x:Name="ContentFrame"
                           Grid.Row="1"
                           Margin="0,22,0,0"
                           NavigationUIVisibility="Hidden"
                           Background="Transparent" Navigated="ContentFrame_Navigated"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
